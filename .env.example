# Cleanroom — environment variables
# Copy to .env and fill in. Never commit .env.

# --- LLM ---
# Used for: dedup tie-break (Haiku 4.5, gray-zone pairs scored 70–90)
#           report summary narrative (Sonnet 4.6, one call per run)
ANTHROPIC_API_KEY=sk-ant-...

# --- Enrichment ---
# Apollo: firmographic + person enrichment via /v1/organizations/enrich
# Free tier = 100 credits/mo. Cleanroom caches responses to data/enrichment/cache.json
# so dev iteration doesn't burn credits.
APOLLO_API_KEY=

# --- Salesforce push (dev org) ---
# Sign up: https://developer.salesforce.com/signup
# Security token: emailed by SF after password change in Setup → My Personal Information → Reset My Security Token
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=

# Optional: SF domain (defaults to "login" for dev orgs; use "test" for sandboxes)
SF_DOMAIN=login

# --- Local / runtime ---
# Set to "1" to log push actions but skip the actual Bulk API write (safe demo mode)
DRY_RUN=1

# Cap on LLM tie-breaker calls per run (cost guard for the 70–90 gray zone)
LLM_TIEBREAK_CAP=500
